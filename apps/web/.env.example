# --- Clerk (auth) ---
# From the Clerk dashboard: API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Clerk hosted auth routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Clerk webhook signing secret (Clerk dashboard -> Webhooks)
CLERK_WEBHOOK_SECRET=whsec_xxx

# --- Backend ---
# In production this is the deployed FastAPI URL (e.g. https://creator-intel-api.fly.dev).
# It is read by server components / route handlers only — never exposed to the browser.
API_BASE_URL=http://localhost:8000
# Shared secret the web app uses to call FastAPI internal endpoints. Must match the API.
INTERNAL_API_SECRET=change-me-to-a-long-random-string

# --- Stripe (Milestone 8) ---
# Leave STRIPE_SECRET_KEY blank in dev to use the offline billing stub.
# In production, set both; the webhook route verifies the signature before forwarding.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
