# --- Deployment (Milestone 9) ---
# "development" (default) or "production". In production the API/worker refuse to start
# unless the secrets below are real: non-default INTERNAL_API_SECRET, a TOKEN_ENCRYPTION_KEY,
# DB_REQUIRE_SSL=true, a real CLERK_ISSUER, and non-localhost CORS_ORIGINS.
APP_ENV=development

# --- Clerk ---
# Your Clerk Frontend API URL (Clerk dashboard -> API Keys -> "Frontend API URL"),
# e.g. https://your-app.clerk.accounts.dev  or  https://clerk.yourdomain.com
CLERK_ISSUER=https://your-app.clerk.accounts.dev
# Optional explicit JWKS URL (defaults to <issuer>/.well-known/jwks.json)
# CLERK_JWKS_URL=
# Optional comma-separated authorized parties (frontend origins) to enforce
# CLERK_AUTHORIZED_PARTIES=["http://localhost:3000"]

# Shared secret protecting internal endpoints (must match the web app's value)
INTERNAL_API_SECRET=change-me-to-a-long-random-string

# Browser origins allowed to call this API
CORS_ORIGINS=["http://localhost:3000"]

# --- Database (Milestone 3) ---
# Local dev (docker compose in infra/docker):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/creator_intel
# Neon (production): take the pooled connection string, change the scheme to
# postgresql+asyncpg:// and drop any ?sslmode=... — then set DB_REQUIRE_SSL=true
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/creator_intel
DB_REQUIRE_SSL=false
DB_ECHO=false

# Must match the embedding model chosen in Milestone 6 (1536 = small/cheap default).
EMBEDDING_DIM=1536

# --- Milestone 4: YouTube / Google OAuth ---
# Google Cloud console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID (Web app)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx
# Must be listed as an authorized redirect URI on that OAuth client:
GOOGLE_REDIRECT_URI=http://localhost:8000/youtube/oauth/callback
WEB_APP_URL=http://localhost:3000

# Encrypts OAuth tokens at rest. Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Redis for the Arq worker/queue (docker compose provides this locally)
REDIS_URL=redis://localhost:6379

# Import guardrails (YouTube quota)
IMPORT_MAX_VIDEOS=200
IMPORT_MAX_COMMENTS_PER_VIDEO=500

# --- Milestone 5: comment pipeline ---
# "openai" for hosted embeddings, or "deterministic" for offline/dev (no API cost).
# Leaving OPENAI_API_KEY blank auto-falls-back to deterministic embeddings.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_BATCH_SIZE=128
MIN_COMMENT_WORDS=3
MAX_CLUSTERS=80
MIN_COMMENTS_TO_CLUSTER=5

# --- Milestone 6: AI engine (tiered Claude) ---
# Leave blank to use the deterministic offline stub (zero API cost, no semantic quality).
ANTHROPIC_API_KEY=
MODEL_CHEAP=claude-haiku-4-5
MODEL_STANDARD=claude-sonnet-5
MODEL_FLAGSHIP=claude-opus-4-8
PROMPT_VERSION=v1
MEMORY_TOP_K=6

# --- Milestone 8: payments (Stripe) ---
# Leave STRIPE_SECRET_KEY blank to use the offline billing stub (no Stripe account needed;
# checkout redirects back locally and activates the plan via the internal sync endpoint).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (Stripe dashboard -> Developers -> Webhooks). Verified in the web app.
STRIPE_WEBHOOK_SECRET=
# Price ids for each paid plan (Stripe dashboard -> Products). Required only in real mode.
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
# Where Stripe Checkout returns the user:
BILLING_SUCCESS_URL=http://localhost:3000/dashboard/billing?checkout=success
BILLING_CANCEL_URL=http://localhost:3000/dashboard/billing?checkout=cancel
